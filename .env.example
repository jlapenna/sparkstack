# Spark Services Orchestration - Environment Variables
# Copy this file to .env and fill in the appropriate values.
#
# NOTE: Operational, topology, overlay, node targets, and hardware constraints
# are configured in ~/.config/sparkstack/sparkstack.yaml (or sparkstack.yaml in project root).
# Only API keys, secrets, and developer environment path overrides belong in this .env file.

# ------------------------------------------------------------------------------
# API Keys & Secrets
# ------------------------------------------------------------------------------

# Required: The core API key used by the OpenClaw gateway to communicate with vLLM backends
LITELLM_MASTER_KEY=your_secure_vllm_api_key_here

# Required: Token for exposing your local tunnel to the web securely
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# ------------------------------------------------------------------------------
# OpenClaw Configuration
# ------------------------------------------------------------------------------

# Required: Absolute path to the OpenClaw configuration directory
OPENCLAW_CONFIG_DIR=/path/to/openclaw/config

# Required: Absolute path to the OpenClaw workspace directory (e.g. for sqlite db)
OPENCLAW_WORKSPACE_DIR=/path/to/openclaw/workspace

# Optional: Gateway authentication token
OPENCLAW_GATEWAY_TOKEN=your_gateway_auth_token

# ------------------------------------------------------------------------------
# External LLM Provider Sessions (Optional)
# ------------------------------------------------------------------------------

CLAUDE_AI_SESSION_KEY=your_claude_ai_session_key
CLAUDE_WEB_SESSION_KEY=your_claude_web_session_key
CLAUDE_WEB_COOKIE=your_claude_web_cookie

# ------------------------------------------------------------------------------
# Observability / Monitoring (Prometheus & Grafana)
# ------------------------------------------------------------------------------

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=strong_grafana_password

# ------------------------------------------------------------------------------
# Detached Service Locations (Standalone Repositories)
# ------------------------------------------------------------------------------

# The 'sparkrun' command to execute. Defaults to searching in PATH or using uv run.
# Set this if you want to use a specific binary or wrapper.
SPARKRUN_BIN=uv run sparkrun

# The absolute path to the detached sparkrun source code repository.
# Used by scripts/update_sparkrun.py to pull updates.
SPARKRUN_DIR=/path/to/sparkrun

# The absolute path to the detached openclaw source code repository.
# Used by scripts/update_openclaw.py to pull updates.
OPENCLAW_DIR=/path/to/openclaw

# ------------------------------------------------------------------------------
# Spark Ecosystem Paths
# ------------------------------------------------------------------------------

# Required: The absolute path to the local sparkstack root directory
SPARK_STACK_ROOT=/path/to/sparkstack

# Required: Absolute path to the sparkstack-registry source dependency
SPARK_STACK_REGISTRY=/path/to/sparkstack/sparkstack-registry

# ------------------------------------------------------------------------------
# Monitoring & StatsD
# ------------------------------------------------------------------------------

SPARKRUN_STATSD_HOST=127.0.0.1
SPARKRUN_STATSD_PORT=8125

# ------------------------------------------------------------------------------
# Python Environment
# ------------------------------------------------------------------------------

# Required: Enables relative imports for the project's module structure
PYTHONPATH=.

# The directory containing custom skills to install into the OpenClaw sandbox.
SPARK_STACK_OPENCLAW_SKILLS_DIR=/path/to/sparkstack/services/openclaw/skills
