        "text": {
          "titleSize": 14,
          "valueSize": 36
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(litellm_request_total_latency_metric_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(litellm_request_total_latency_metric_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "title": "LLM Latency",
      "type": "stat",
      "description": "P95 and P50 End-to-End Response Latency (LiteLLM)"
    },
    {
      "datasource": {
