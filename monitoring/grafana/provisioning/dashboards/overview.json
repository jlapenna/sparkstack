    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "reqps"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Errors"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name",
        "text": {
          "titleSize": 14,
          "valueSize": 36
        }
      },
      "targets": [
        {
          "expr": "sum(rate(litellm_proxy_total_requests_metric_total[$__rate_interval])) or vector(0)",
          "legendFormat": "Rate"
        },
        {
          "expr": "sum(increase(litellm_proxy_failed_requests_metric_total[$__rate_interval])) or vector(0)",
          "legendFormat": "Errors"
        }
      ],
      "title": "Gateway Traffic",
      "type": "stat",
      "description": "Aggregate request rates and errors across the LiteLLM proxy gateway."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2.0
              },
              {
                "color": "red",
                "value": 5.0
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "id": 100,
      "options": {
        "colorMode": "value",
