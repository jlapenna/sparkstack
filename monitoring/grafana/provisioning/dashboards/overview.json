          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (model) (label_replace(vllm:num_requests_running, \"model\", \"$1\", \"model_name\", \"(.*)\")) or sum by (model) (label_replace(sglang:num_running_reqs, \"model\", \"$1\", \"model_name\", \"(.*)\"))",
          "legendFormat": "{{model}} Active"
        },
        {
          "expr": "sum by (model) (label_replace(vllm:num_requests_waiting, \"model\", \"$1\", \"model_name\", \"(.*)\")) or sum by (model) (label_replace(sglang:num_queue_reqs, \"model\", \"$1\", \"model_name\", \"(.*)\"))",
          "legendFormat": "{{model}} Queued"
        }
      ],
      "title": "Active & Queued Requests",
      "type": "timeseries",
      "description": "Requests currently being actively processed or sitting in the backlog waiting for KV cache."
    },
    {
