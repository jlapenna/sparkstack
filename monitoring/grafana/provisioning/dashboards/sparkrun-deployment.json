        {
          "expr": "vllm_vllm_sparkrun_deploy_status",
          "legendFormat": "{{service}}",
          "refId": "A",
          "range": true
        }
      ],
      "options": {
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "always"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 70
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "index": 0,
                  "text": "Waiting",
                  "color": "gray"
                },
                "1": {
                  "index": 1,
                  "text": "Running",
                  "color": "blue"
                },
                "2": {
                  "index": 2,
                  "text": "Complete",
                  "color": "green"
                },
                "3": {
                  "index": 3,
                  "text": "Failed",
                  "color": "red"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "gray",
                "value": null
              },
              {
                "color": "blue",
                "value": 1
              },
              {
                "color": "green",
                "value": 2
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        }
      },
      "transparent": true
    }
